#!/usr/bin/env python3
"""
Proximus-Nova CLI Launcher
Boots the Amazon Nova powered AI multi-agent platform and Next.js UI locally.
"""

import argparse
import subprocess
import time
import webbrowser
import sys
import os

def print_banner():
    print(r"""
    ____  ____  ____ _  __I__  __  _____  _______
   / __ \/ __ \/ __ \ |/ /_/__/ / / /   |/ __/  /
  / /_/ / /_/ / / / /   / / __  / / / /| |\ \ / / 
 / ____/ _, _/ /_/ /   | / / / / / / / | |_\ \  /  
/_/   /_/ |_|\____/_/|_||_/ /_/\____/  |/____/ /   
                                                   
   PROXIMUS-NOVA - Multi-Agent AI System
=====================================================
    """)


def open_app_mode(url):
    print(f"[*] Opening physical browser window in App Mode to {url}...")
    
    # Common browser executables for App Mode
    browsers = []
    
    if sys.platform == "win32":
        paths = [
            r"C:\Program Files\Google\Chrome\Application\chrome.exe",
            r"C:\Program Files (x86)\Google\Chrome\Application\chrome.exe",
            r"C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe",
            r"C:\Program Files\BraveSoftware\Brave-Browser\Applicationrave.exe",
        ]
        browsers.extend([p for p in paths if os.path.exists(p)])
    elif sys.platform == "darwin":
        paths = [
            "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
            "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge",
            "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser",
            "/Applications/Chromium.app/Contents/MacOS/Chromium",
        ]
        browsers.extend([p for p in paths if os.path.exists(p)])
    else:
        # Linux names
        linux_cmds = [
            "google-chrome",
            "google-chrome-stable",
            "chromium",
            "chromium-browser",
            "microsoft-edge",
            "microsoft-edge-stable",
            "brave-browser"
        ]
        for cmd in linux_cmds:
            try:
                if subprocess.run(["which", cmd], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0:
                    browsers.append(cmd)
            except Exception:
                pass

    if browsers:
        browser_cmd = browsers[0]
        try:
            # Popen ensures we don't block the python script while browser is open
            subprocess.Popen([browser_cmd, f"--app={url}"])
            return True
        except Exception as e:
            print(f"[!] Warning: Failed to launch app mode: {e}")
            
    # Fallback
    print("[*] Falling back to default browser tab...")
    try:
        webbrowser.open(url)
        return True
    except Exception:
        print(f"Navigate to {url} in your browser.")
        return False

def run_system():
    print("[*] Checking Docker daemon...")
    try:
        subprocess.run(["docker", "info"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        print("[!] Error: Docker is not running. Please start Docker first.")
        sys.exit(1)

    print("[*] Booting up Proximus-Nova multi-agent platform (Go orchestrator, Rust moe-scoring, Next.js, Agents)...")
    try:
        # Assuming there is a root docker-compose.yml or docker-compose.local.yml
        compose_cmd = ["docker", "compose", "up", "-d", "--build"]
        
        # Check if local compose exists for prioritizing local run
        if os.path.exists("docker-compose.local.yml"):
            compose_cmd = ["docker", "compose", "-f", "docker-compose.local.yml", "up", "-d", "--build"]
            
        subprocess.run(compose_cmd, check=True)
        
        print("\n[*] Native services started successfully!")
    except subprocess.CalledProcessError as e:
        print(f"\n[!] Failed to start services: {e}")
        sys.exit(1)

    print("\n[*] Waiting for Next.js Dashboard to become ready (port 3000)...")
    for _ in range(15):
        try:
            # Simple curl check
            res = subprocess.run(["curl", "-s", "http://localhost:3000"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            if res.returncode == 0:
                break
        except Exception:
            pass
        time.sleep(1)

    print("[*] Proximus-Nova is online.")
    print("[*] Opening physical browser window to the Dashboard...")
    
    # Open dashboard in App-mode
    open_app_mode("http://localhost:3000")
        
    print("\n[+] To safely tear down the platform, run: proximus-nova stop\n")

def stop_system(prune=False):
    print(f"[*] {'Cleaning' if prune else 'Tearing down'} Proximus-Nova multi-agent platform...")
    compose_cmd = ["docker", "compose", "down"]
    if prune:
        compose_cmd.append("-v")
        
    if os.path.exists("docker-compose.local.yml"):
        compose_cmd = ["docker", "compose", "-f", "docker-compose.local.yml", "down"]
        if prune:
            compose_cmd.append("-v")
        
    subprocess.run(compose_cmd)
    if prune:
        print("\n[*] Volumes cleared. Fresh start ready.")
    else:
        print("\n[*] Offline.")

def main():
    parser = argparse.ArgumentParser(description="Proximus-Nova CLI Launcher")
    parser.add_argument("command", choices=["start", "stop", "clean", "tui"], help="Action to perform")
    
    args = parser.parse_args()
    
    print_banner()
    
    if args.command == "start":
        run_system()
    elif args.command == "stop":
        stop_system()
    elif args.command == "clean":
        stop_system(prune=True)
    elif args.command == "tui":
        tui_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "tui.py")
        print("[*] Launching Terminal UI in a separate window...")
        
        if sys.platform == "win32":
            subprocess.Popen(["cmd.exe", "/c", "start", sys.executable, tui_path])
        elif sys.platform == "darwin":
            subprocess.Popen(["osascript", "-e", f'tell app "Terminal" to do script "{sys.executable} {tui_path}"'])
        else:
            terminals = [
                ["gnome-terminal", "--", sys.executable, tui_path],
                ["konsole", "-e", sys.executable, tui_path],
                ["xterm", "-e", sys.executable, tui_path],
                ["x-terminal-emulator", "-e", f"{sys.executable} {tui_path}"]
            ]
            
            launched = False
            for cmd in terminals:
                try:
                    if subprocess.run(["which", cmd[0]], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0:
                        subprocess.Popen(cmd)
                        launched = True
                        break
                except Exception:
                    continue
                    
            if not launched:
                print("[!] Could not launch separate terminal window. Falling back to current terminal...")
                subprocess.run([sys.executable, tui_path])

if __name__ == "__main__":
    main()
